{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Default capability for Tunante",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"dialog:default",
		"dialog:allow-open",
		"fs:default",
		"core:window:allow-set-title",
		"core:window:allow-title",
		"core:window:allow-show",
		"core:tray:default",
		"process:allow-restart",
		"process:allow-exit"
	]
}
