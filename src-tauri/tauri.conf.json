{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "Tunante",
	"version": "0.1.0",
	"identifier": "com.tunante.app",
	"build": {
		"frontendDist": "../build",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "npm run kill-port; npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "Tunante",
				"width": 1200,
				"height": 800,
				"minWidth": 800,
				"minHeight": 600,
				"visible": false,
				"decorations": true,
				"backgroundColor": "#1e1e1e"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"createUpdaterArtifacts": true
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0QThFOUQ0MjZBMTY0MjMKUldRalpLRW0xT21vaEU1SS9yc2ZGZXBJUGRtZGlsRDhXZTA2RldJUHVPbXpvM1VXS1F6dFQzMGwK",
			"endpoints": [
				"https://github.com/jjolmo/tunante/releases/latest/download/latest.json"
			]
		}
	}
}
