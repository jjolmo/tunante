[package]
name = "opus-decoder"
version = "0.1.1"
edition.workspace = true
rust-version = "1.85"
description = "Pure-Rust Opus decoder — RFC 8251 conformant, no unsafe, no FFI"
license = "MIT OR Apache-2.0"
repository = "https://github.com/TadeuszWolfGang/Rusopus"
homepage = "https://github.com/TadeuszWolfGang/Rusopus"
documentation = "https://docs.rs/opus-decoder"
readme = "../../README.md"
keywords = ["opus", "audio", "codec", "decoder", "rfc8251"]
categories = ["multimedia::audio"]
exclude = ["testdata/", "benches/", ".github/"]

[dependencies]
thiserror = "2.0.18"

[dev-dependencies]
criterion = { version = "0.5", features = ["html_reports"] }

[[bench]]
name = "decode"
harness = false
